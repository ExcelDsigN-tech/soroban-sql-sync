# Soroban SQL Sync — Local Development Configuration
# Copy this file to .env and fill in the values

# PostgreSQL connection URL
DATABASE_URL=postgres://postgres:password@localhost:5432/soroban_sql_sync

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-rpc.stellar.org

# Comma-separated list of contract IDs to watch
CONTRACT_IDS=CA123456789ABCDEF,CA987654321FEDCBA

# Logging level (debug, info, warn, error)
RUST_LOG=info

# API server port (future use)
API_PORT=8080
